# ============================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file as .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/siet_profile?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD

# ------------------------------------------------------------
# JWT CONFIGURATION
# ------------------------------------------------------------
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# ------------------------------------------------------------
# SMTP (OUTGOING EMAIL) CREDENTIALS
# Used for password reset emails
# Generate Gmail App Password: https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ------------------------------------------------------------
# ADMIN EMAIL
# ------------------------------------------------------------
ADMIN_EMAIL=admin@siet.ac.in

# ------------------------------------------------------------
# AWS S3 CONFIGURATION
# Used for file storage (photos, resumes, certificates)
# ------------------------------------------------------------
AWS_S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
AWS_S3_SECRET_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET_NAME=YOUR_BUCKET_NAME
AWS_S3_REGION=ap-south-2
